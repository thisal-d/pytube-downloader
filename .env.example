# PyTube Downloader — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Download directory (default: ./downloads)
# DOWNLOAD_DIR=./downloads

# Max simultaneous downloads (default: 3)
# MAX_SIMULTANEOUS_DOWNLOADS=3

# Chunk size in bytes (default: 2097152 = 2 MB)
# CHUNK_SIZE=2097152

# Language (default: en)
# LANG=en

# Theme (dark_default, light_default, cyberpunk_black)
# THEME=dark_default
